{
  "name": "Measurement Honesty",
  "dataColors": [
    "#2563EB",
    "#0EA5A4",
    "#F59E0B",
    "#DC2626",
    "#7C3AED",
    "#475569",
    "#16A34A",
    "#DB2777"
  ],
  "good": "#16A34A",
  "neutral": "#F59E0B",
  "bad": "#DC2626",
  "maximum": "#2563EB",
  "center": "#93C5FD",
  "minimum": "#EFF6FF",
  "background": "#FFFFFF",
  "foreground": "#1C1917",
  "tableAccent": "#2563EB",
  "textClasses": {
    "title": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#1C1917"
    },
    "callout": {
      "fontSize": 30,
      "fontFace": "Segoe UI",
      "color": "#1C1917"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#57534E"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#1C1917"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E7E5E0" } },
            "radius": 10
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#44403C" } },
            "background": { "solid": { "color": "#FFFFFF" } },
            "alignment": "left",
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#FAFAF7" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#F2F1EC" } },
            "transparency": 0
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    }
  }
