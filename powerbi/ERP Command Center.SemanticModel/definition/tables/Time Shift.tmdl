/// Calculation group: apply week arithmetic to ANY measure. Uses the gapless
/// Week Ordinal so shifts never break at year boundaries.
///
/// Every item anchors on MIN ( MAX ( DimWeek[Week Ordinal] ), [_Last Full Week
/// Ordinal] ) rather than MAX alone. The clamp is the whole point: MAX in an
/// unfiltered card is the CURRENT, still-open week, so "WoW %" on any measure
/// would have compared a two-day week against a full one - the exact trap this
/// project exists to prevent, hiding inside the generic tool. Clamping (rather
/// than pinning to the last full week outright) keeps the per-row behaviour a
/// week-sliced table needs: each row still anchors on its own week, it just
/// cannot anchor on a partial one.
///
/// The "+ 0" inside AVERAGEX is load-bearing too: an empty week returns BLANK and
/// AVERAGEX skips blanks, which would quietly shrink the divisor and read higher
/// than the engine, which counts an empty week as a zero.
table 'Time Shift'
	lineageTag: 67a9115c-0014-4000-8000-000000000014

	calculationGroup
		precedence: 1

		calculationItem Current = SELECTEDMEASURE ()

		calculationItem 'Previous Week' =
				VAR w = MIN ( MAX ( DimWeek[Week Ordinal] ), [_Last Full Week Ordinal] )
				RETURN
				    CALCULATE (
				        SELECTEDMEASURE (),
				        REMOVEFILTERS ( DimWeek ),
				        DimWeek[Week Ordinal] = w - 1
				    )

		calculationItem 'WoW Change' =
				VAR w = MIN ( MAX ( DimWeek[Week Ordinal] ), [_Last Full Week Ordinal] )
				VAR curr =
				    CALCULATE (
				        SELECTEDMEASURE (),
				        REMOVEFILTERS ( DimWeek ),
				        DimWeek[Week Ordinal] = w
				    )
				VAR prev =
				    CALCULATE (
				        SELECTEDMEASURE (),
				        REMOVEFILTERS ( DimWeek ),
				        DimWeek[Week Ordinal] = w - 1
				    )
				RETURN
				    curr - prev

		calculationItem 'WoW %' =
				VAR w = MIN ( MAX ( DimWeek[Week Ordinal] ), [_Last Full Week Ordinal] )
				VAR curr =
				    CALCULATE (
				        SELECTEDMEASURE (),
				        REMOVEFILTERS ( DimWeek ),
				        DimWeek[Week Ordinal] = w
				    )
				VAR prev =
				    CALCULATE (
				        SELECTEDMEASURE (),
				        REMOVEFILTERS ( DimWeek ),
				        DimWeek[Week Ordinal] = w - 1
				    )
				RETURN
				    DIVIDE ( curr - prev, prev )

			formatStringDefinition = "+0.0%;-0.0%;0.0%"

		calculationItem '8-Week Baseline' =
				VAR w = MIN ( MAX ( DimWeek[Week Ordinal] ), [_Last Full Week Ordinal] )
				RETURN
				    AVERAGEX (
				        FILTER (
				            ALL ( DimWeek ),
				            DimWeek[Week Ordinal] >= w - 8
				                && DimWeek[Week Ordinal] <= w - 1
				                && DimWeek[Is Full Week] = 1
				        ),
				        CALCULATE ( SELECTEDMEASURE () ) + 0
				    )

		calculationItem 'vs Baseline %' =
				VAR w = MIN ( MAX ( DimWeek[Week Ordinal] ), [_Last Full Week Ordinal] )
				VAR curr =
				    CALCULATE (
				        SELECTEDMEASURE (),
				        REMOVEFILTERS ( DimWeek ),
				        DimWeek[Week Ordinal] = w
				    )
				VAR base =
				    AVERAGEX (
				        FILTER (
				            ALL ( DimWeek ),
				            DimWeek[Week Ordinal] >= w - 8
				                && DimWeek[Week Ordinal] <= w - 1
				                && DimWeek[Is Full Week] = 1
				        ),
				        CALCULATE ( SELECTEDMEASURE () ) + 0
				    )
				RETURN
				    DIVIDE ( curr - base, base )

			formatStringDefinition = "+0.0%;-0.0%;0.0%"

	column Shift
		dataType: string
		lineageTag: 67a9115c-0015-4000-8000-000000000015
		summarizeBy: none
		sourceColumn: Name
		sortByColumn: Ordinal

		annotation SummarizationSetBy = Automatic

	column Ordinal
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 67a9115c-0016-4000-8000-000000000016
		summarizeBy: none
		sourceColumn: Ordinal

		annotation SummarizationSetBy = User
